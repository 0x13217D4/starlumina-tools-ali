.container {
  padding: 20px;
  min-height: 100vh;
  background-color: #ffffff;
}

/* 深色模式 */
.container.dark {
  background-color: #1a1a1a;
}

.header {
  margin-bottom: 30px;
  text-align: center;
  font-size: 18px;
  font-weight: bold;
  color: #333;
}

.container.dark .header {
  color: #e0e0e0;
}

.scales-list {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.scale-item {
  padding: 15px;
  background-color: #f5f5f5;
  border-radius: 8px;
  color: #333;
  display: flex;
  align-items: center;
}

.container.dark .scale-item {
  background-color: #2d2d2d;
  color: #e0e0e0;
}

.scale-info {
  flex: 1;
}

.scale-name {
  font-size: 16px;
  font-weight: bold;
  display: block;
  margin-bottom: 5px;
}

.scale-desc {
  font-size: 14px;
  color: #666;
  display: block;
  margin-bottom: 5px;
}

.container.dark .scale-desc {
  color: #aaa;
}

.scale-count {
  font-size: 12px;
  color: #999;
  display: block;
}

.container.dark .scale-count {
  color: #888;
}

.arrow {
  width: 12px;
  height: 12px;
  opacity: 0.6;
  border-right: 2px solid #999;
  border-bottom: 2px solid #999;
  transform: rotate(-45deg);
}